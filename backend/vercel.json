{
    "version": 2,
    "builds": [
        {
            "src": "src/app.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/app.py"
        }
    ],
    "crons": [
        {
        "path": "/internal/weekly-summary",
        "schedule": "0 9 * * 0"
        }
    ]
}
